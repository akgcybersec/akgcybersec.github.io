---
import BaseLayout from './BaseLayout.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags: string[];
}

const { title, description, date, updated, tags } = Astro.props;
const formatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout title={title} description={description}>
  <article class="container-x py-16 md:py-24">
    <div class="mx-auto max-w-3xl">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 font-mono text-xs text-[color:var(--color-text-dim)] hover:text-[color:var(--color-accent)] transition"
      >
        <Icon name="lucide:arrow-left" class="w-4 h-4" />
        Back to blog
      </a>

      <header class="mt-8 pb-8" style="border-bottom: 1px solid var(--color-border);">
        <div class="flex flex-wrap gap-1.5 mb-4">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
        <h1 class="font-display text-3xl md:text-5xl font-bold leading-tight tracking-tight text-[color:var(--color-text)]">
          {title}
        </h1>
        <p class="mt-4 text-lg text-[color:var(--color-text-dim)]">{description}</p>
        <div class="mt-6 flex flex-wrap items-center gap-4 font-mono text-xs text-[color:var(--color-text-muted)]">
          <span class="flex items-center gap-2">
            <Icon name="lucide:calendar" class="w-4 h-4 text-[color:var(--color-accent)]" />
            {formatter.format(date)}
          </span>
          {updated && (
            <span class="flex items-center gap-2">
              <Icon name="lucide:refresh-cw" class="w-4 h-4 text-[color:var(--color-accent)]" />
              Updated {formatter.format(updated)}
            </span>
          )}
        </div>
      </header>

      <div class="prose prose-invert prose-invert-custom mt-10 max-w-none">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
