---
import BaseLayout from './BaseLayout.astro';
import { Icon } from 'astro-icon/components';

import type { BlogReference, BlogRelated } from '../data/blog-references';

interface SeriesLink {
  title: string;
  href: string;
  part: number;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags: string[];
  seriesTitle?: string;
  seriesPart?: number;
  prevInSeries?: SeriesLink;
  nextInSeries?: SeriesLink;
  references?: BlogReference[];
  related?: BlogRelated[];
}

const {
  title,
  description,
  date,
  updated,
  tags,
  seriesTitle,
  seriesPart,
  prevInSeries,
  nextInSeries,
  references = [],
  related = [],
} = Astro.props;
const formatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout title={title} description={description}>
  <article class="container-x py-16 md:py-24">
    <div class="mx-auto max-w-3xl">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 font-mono text-xs text-[color:var(--color-text-dim)] hover:text-[color:var(--color-accent)] transition"
      >
        <Icon name="lucide:arrow-left" class="w-4 h-4" />
        Back to blog
      </a>

      <header class="mt-8 pb-8" style="border-bottom: 1px solid var(--color-border);">
        <div class="flex flex-wrap gap-1.5 mb-4">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
        <h1 class="font-display text-3xl md:text-5xl font-bold leading-tight tracking-tight text-[color:var(--color-text)]">
          {title}
        </h1>
        <p class="mt-4 text-lg text-[color:var(--color-text-dim)]">{description}</p>
        <div class="mt-6 flex flex-wrap items-center gap-4 font-mono text-xs text-[color:var(--color-text-muted)]">
          <span class="flex items-center gap-2">
            <Icon name="lucide:calendar" class="w-4 h-4 text-[color:var(--color-accent)]" />
            {formatter.format(date)}
          </span>
          {updated && (
            <span class="flex items-center gap-2">
              <Icon name="lucide:refresh-cw" class="w-4 h-4 text-[color:var(--color-accent)]" />
              Updated {formatter.format(updated)}
            </span>
          )}
        </div>
      </header>

      <div class="prose prose-invert prose-invert-custom mt-10 max-w-none">
        <slot />
      </div>

      {(references.length > 0 || related.length > 0) && (
        <footer
          class="mt-16 pt-8 space-y-10"
          style="border-top: 1px solid var(--color-border);"
        >
          {references.length > 0 && (
            <section aria-labelledby="blog-references-heading">
              <h2
                id="blog-references-heading"
                class="font-display text-xl font-semibold text-[color:var(--color-text)]"
              >
                References
              </h2>
              <ul class="mt-4 space-y-2 text-sm text-[color:var(--color-text-dim)]">
                {references.map((ref) => (
                  <li>
                    <a
                      href={ref.url}
                      class="text-[color:var(--color-accent)] hover:underline break-all"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {ref.title}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
          {related.length > 0 && (
            <section aria-labelledby="blog-related-heading">
              <h2
                id="blog-related-heading"
                class="font-display text-xl font-semibold text-[color:var(--color-text)]"
              >
                Related reading
              </h2>
              <ul class="mt-4 space-y-2 text-sm">
                {related.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="text-[color:var(--color-accent)] hover:underline"
                    >
                      {item.title}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </footer>
      )}

      {(prevInSeries || nextInSeries) && (
        <nav
          class="mt-16 pt-8"
          style="border-top: 1px solid var(--color-border);"
          aria-label="Series navigation"
        >
          {seriesTitle && seriesPart && (
            <p class="font-mono text-xs uppercase tracking-wider text-[color:var(--color-text-muted)] mb-6">
              {seriesTitle} · Part {seriesPart}
            </p>
          )}
          <div class="grid gap-4 sm:grid-cols-2">
            {prevInSeries ? (
              <a
                href={prevInSeries.href}
                class="group flex flex-col gap-1 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-bg-card)] p-4 transition hover:border-[color:var(--color-accent-dim)] hover:bg-[color:var(--color-bg-elev)]"
              >
                <span class="inline-flex items-center gap-1.5 font-mono text-xs text-[color:var(--color-text-muted)] group-hover:text-[color:var(--color-accent)]">
                  <Icon name="lucide:arrow-left" class="w-3.5 h-3.5" />
                  Previous
                </span>
                <span class="text-sm font-medium text-[color:var(--color-text)] group-hover:text-[color:var(--color-accent)]">
                  Part {prevInSeries.part}: {prevInSeries.title}
                </span>
              </a>
            ) : (
              <div />
            )}
            {nextInSeries && (
              <a
                href={nextInSeries.href}
                class="group flex flex-col gap-1 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-bg-card)] p-4 transition hover:border-[color:var(--color-accent-dim)] hover:bg-[color:var(--color-bg-elev)] sm:text-right sm:items-end"
              >
                <span class="inline-flex items-center gap-1.5 font-mono text-xs text-[color:var(--color-text-muted)] group-hover:text-[color:var(--color-accent)]">
                  Next
                  <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
                </span>
                <span class="text-sm font-medium text-[color:var(--color-text)] group-hover:text-[color:var(--color-accent)]">
                  Part {nextInSeries.part}: {nextInSeries.title}
                </span>
              </a>
            )}
          </div>
        </nav>
      )}
    </div>
  </article>
</BaseLayout>
