---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const formatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<section id="blog-preview" class="py-20 md:py-28" style="background: var(--color-bg-elev); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
  <div class="container-x">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
      <div>
        <div class="section-label"><span>04 // writing</span></div>
        <h2 class="section-title mb-0">Latest from the blog</h2>
      </div>
      <a href="/blog" class="btn-ghost">
        All posts
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>

    {posts.length === 0 ? (
      <div class="card text-center py-16">
        <Icon name="lucide:file-text" class="w-8 h-8 mx-auto text-[color:var(--color-text-muted)]" />
        <p class="mt-3 text-[color:var(--color-text-dim)]">No posts yet — check back soon.</p>
      </div>
    ) : (
      <div class="grid gap-4 md:grid-cols-3">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="card group flex flex-col">
            <div class="font-mono text-xs text-[color:var(--color-text-muted)]">
              {formatter.format(post.data.date)}
            </div>
            <h3 class="mt-3 font-display text-lg font-semibold text-[color:var(--color-text)] group-hover:text-[color:var(--color-accent)] transition">
              {post.data.title}
            </h3>
            <p class="mt-2 text-sm text-[color:var(--color-text-dim)] flex-1">
              {post.data.description}
            </p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {post.data.tags.slice(0, 3).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>
