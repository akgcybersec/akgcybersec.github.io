---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const [featured, ...rest] = posts;

const formatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<section id="writing" class="py-20 md:py-28" style="background: var(--color-bg-elev); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
  <div class="container-x">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
      <div>
        <div class="section-label"><span>01 // writing</span></div>
        <h2 class="section-title mb-0">From the field</h2>
      </div>
      <a href="/blog" class="btn-ghost">
        All posts
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>

    {posts.length === 0 ? (
      <div class="card text-center py-16">
        <Icon name="lucide:file-text" class="w-8 h-8 mx-auto text-[color:var(--color-text-muted)]" />
        <p class="mt-3 text-[color:var(--color-text-dim)]">No posts yet — check back soon.</p>
      </div>
    ) : (
      <div class="space-y-4">
        {/* Featured / latest post */}
        <a
          href={`/blog/${featured.id}/`}
          class="card group block"
          style="border-color: rgba(255,176,32,0.25);"
        >
          <div class="flex flex-col md:flex-row md:items-start gap-6">
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <span
                  class="font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 rounded"
                  style="background: var(--color-accent-glow); border: 1px solid rgba(255,176,32,0.3); color: var(--color-accent);"
                >
                  latest
                </span>
                <span class="font-mono text-xs text-[color:var(--color-text-muted)]">
                  {formatter.format(featured.data.date)}
                </span>
              </div>
              <h3 class="font-display text-2xl md:text-3xl font-bold leading-tight text-[color:var(--color-text)] group-hover:text-[color:var(--color-accent)] transition">
                {featured.data.title}
              </h3>
              <p class="mt-3 text-[color:var(--color-text-dim)] leading-relaxed max-w-2xl">
                {featured.data.description}
              </p>
              <div class="mt-4 flex flex-wrap items-center gap-4">
                <div class="flex flex-wrap gap-1.5">
                  {featured.data.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <span class="ml-auto font-mono text-xs text-[color:var(--color-accent)] inline-flex items-center gap-1.5">
                  Read the post
                  <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5" />
                </span>
              </div>
            </div>
          </div>
        </a>

        {/* Remaining posts as compact list */}
        {rest.length > 0 && (
          <div class="space-y-2 pt-2">
            {rest.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class="card flex flex-col sm:flex-row sm:items-baseline gap-3 sm:gap-6 group"
              >
                <div class="font-mono text-xs text-[color:var(--color-text-muted)] shrink-0 sm:w-24">
                  {formatter.format(post.data.date)}
                </div>
                <div class="flex-1 min-w-0">
                  <span class="font-display font-semibold text-[color:var(--color-text)] group-hover:text-[color:var(--color-accent)] transition">
                    {post.data.title}
                  </span>
                  <div class="mt-1.5 flex flex-wrap gap-1.5">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>
                <Icon
                  name="lucide:arrow-up-right"
                  class="w-4 h-4 text-[color:var(--color-text-muted)] group-hover:text-[color:var(--color-accent)] transition shrink-0"
                />
              </a>
            ))}
          </div>
        )}
      </div>
    )}
  </div>
</section>
