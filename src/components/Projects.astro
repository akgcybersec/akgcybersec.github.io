---
import { projects } from '../data/projects';
import { Icon } from 'astro-icon/components';

const categoryIcon: Record<string, string> = {
  'Offensive Dev': 'lucide:binary',
  'Red Team Tooling': 'lucide:swords',
  'Recon & Reporting': 'lucide:file-search',
  'Utility': 'lucide:wrench',
};
---
<section id="projects" class="py-20 md:py-28">
  <div class="container-x">
    <div class="section-label"><span>03 // projects</span></div>
    <h2 class="section-title">Selected work</h2>
    <p class="mb-10 max-w-2xl text-[color:var(--color-text-dim)]">
      Public tooling and research. The interesting engagements live under NDA — these are
      the things I can talk about openly.
    </p>

    <div class="space-y-4">
      {projects.map((project) => (
        <div
          class="card group relative"
          style={project.highlight ? 'border-color: rgba(255,176,32,0.35);' : ''}
        >
          <div class="flex flex-col sm:flex-row sm:items-start gap-5">
            <div class="sm:w-40 shrink-0 flex sm:flex-col sm:items-start items-center gap-3 sm:gap-2">
              <div
                class="inline-flex items-center justify-center w-9 h-9 rounded-md flex-shrink-0"
                style="background: var(--color-accent-glow); border: 1px solid rgba(255,176,32,0.2);"
              >
                <Icon
                  name={categoryIcon[project.category] ?? 'lucide:folder-git-2'}
                  class="w-4 h-4 text-[color:var(--color-accent)]"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <span class="font-mono text-[10px] uppercase tracking-wider text-[color:var(--color-text-muted)]">
                  {project.category}
                </span>
                {project.highlight && (
                  <span
                    class="font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 rounded self-start"
                    style="background: var(--color-accent-glow); border: 1px solid rgba(255,176,32,0.3); color: var(--color-accent);"
                  >
                    featured
                  </span>
                )}
              </div>
            </div>

            <div class="flex-1 min-w-0">
              <a
                href={project.url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-baseline gap-2 group/link"
              >
                <Icon
                  name="simple-icons:github"
                  class="w-4 h-4 text-[color:var(--color-text-dim)] flex-shrink-0 self-center"
                />
                <h3 class="font-display text-lg font-semibold text-[color:var(--color-text)] group-hover/link:text-[color:var(--color-accent)] transition">
                  {project.name}
                </h3>
                <Icon
                  name="lucide:arrow-up-right"
                  class="w-3.5 h-3.5 text-[color:var(--color-text-muted)] group-hover/link:text-[color:var(--color-accent)] transition self-center"
                />
              </a>

              <p class="mt-1 text-sm text-[color:var(--color-accent)]">
                {project.tagline}
              </p>

              <p class="mt-3 text-sm text-[color:var(--color-text-dim)] leading-relaxed">
                {project.description}
              </p>

              <div class="mt-4 flex flex-wrap items-center gap-4">
                <div class="flex flex-wrap gap-1.5">
                  {project.tech.map((t) => (
                    <span
                      class="font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 rounded"
                      style="background: var(--color-bg-elev); border: 1px solid var(--color-border); color: var(--color-text-dim);"
                    >
                      {t}
                    </span>
                  ))}
                </div>

                {project.writeup && (
                  <a
                    href={project.writeup}
                    class="font-mono text-xs text-[color:var(--color-accent)] hover:underline inline-flex items-center gap-1.5 ml-auto"
                  >
                    <Icon name="lucide:book-open" class="w-3 h-3" />
                    read the writeup →
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a
        href="https://github.com/akgcybersec"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 font-mono text-sm text-[color:var(--color-text-dim)] hover:text-[color:var(--color-accent)] transition"
      >
        <Icon name="simple-icons:github" class="w-4 h-4" />
        more on github →
      </a>
    </div>
  </div>
</section>
