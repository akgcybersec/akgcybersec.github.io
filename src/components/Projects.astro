---
import { projects } from '../data/projects';
import { Icon } from 'astro-icon/components';

const categoryIcon: Record<string, string> = {
  'Offensive Dev': 'lucide:binary',
  'Red Team Tooling': 'lucide:swords',
  'Recon & Reporting': 'lucide:file-search',
  'Utility': 'lucide:wrench',
};
---
<section id="projects" class="py-20 md:py-28">
  <div class="container-x">
    <div class="section-label"><span>03 // projects</span></div>
    <h2 class="section-title">Selected work</h2>
    <p class="mb-10 max-w-2xl text-[color:var(--color-text-dim)]">
      Public tooling and research. The interesting engagements live under NDA — these are
      the things I can talk about openly.
    </p>

    <div class="grid gap-4 md:grid-cols-2">
      {projects.map((project) => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener"
          class="card group relative flex flex-col overflow-hidden transition hover:-translate-y-0.5"
          style={project.highlight ? 'border-color: rgba(255,176,32,0.35);' : ''}
        >
          {project.highlight && (
            <span
              class="absolute right-3 top-3 font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 rounded"
              style="background: var(--color-accent-glow); border: 1px solid rgba(255,176,32,0.3); color: var(--color-accent);"
            >
              featured
            </span>
          )}

          <div class="flex items-center gap-2.5">
            <Icon name={categoryIcon[project.category] ?? 'lucide:folder-git-2'} class="w-4 h-4 text-[color:var(--color-accent)]" />
            <span class="font-mono text-xs uppercase tracking-wider text-[color:var(--color-text-muted)]">
              {project.category}
            </span>
          </div>

          <div class="mt-4 flex items-baseline gap-2">
            <Icon name="simple-icons:github" class="w-4 h-4 text-[color:var(--color-text-dim)] flex-shrink-0" />
            <h3 class="font-display text-lg font-semibold text-[color:var(--color-text)] group-hover:text-[color:var(--color-accent)] transition">
              {project.name}
            </h3>
          </div>

          <p class="mt-1 text-sm text-[color:var(--color-accent)]">
            {project.tagline}
          </p>

          <p class="mt-3 text-sm text-[color:var(--color-text-dim)] leading-relaxed flex-1">
            {project.description}
          </p>

          <div class="mt-4 flex flex-wrap gap-1.5">
            {project.tech.map((t) => (
              <span
                class="font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 rounded"
                style="background: var(--color-bg-elev); border: 1px solid var(--color-border); color: var(--color-text-dim);"
              >
                {t}
              </span>
            ))}
          </div>

          <div class="mt-4 pt-4 border-t flex items-center justify-between" style="border-color: var(--color-border);">
            {project.writeup ? (
              <a
                href={project.writeup}
                class="font-mono text-xs text-[color:var(--color-accent)] hover:underline inline-flex items-center gap-1.5"
                onclick="event.stopPropagation()"
              >
                <Icon name="lucide:book-open" class="w-3 h-3" />
                read the writeup →
              </a>
            ) : (
              <span class="font-mono text-xs text-[color:var(--color-text-muted)] inline-flex items-center gap-1.5">
                <Icon name="simple-icons:github" class="w-3 h-3" />
                view repository →
              </span>
            )}
            <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5 text-[color:var(--color-text-muted)] group-hover:text-[color:var(--color-accent)] transition" />
          </div>
        </a>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a
        href="https://github.com/akgcybersec"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 font-mono text-sm text-[color:var(--color-text-dim)] hover:text-[color:var(--color-accent)] transition"
      >
        <Icon name="simple-icons:github" class="w-4 h-4" />
        more on github →
      </a>
    </div>
  </div>
</section>
