---
import { site } from '../data/site';
import { Icon } from 'astro-icon/components';

const stats = [
  { label: 'Years pentesting', value: '10+' },
  { label: 'Certifications', value: '10' },
  { label: 'Domains covered', value: '5' },
  { label: 'Languages spoken', value: '3' },
];
---
<section id="about" class="py-20 md:py-28">
  <div class="container-x">
    <div class="section-label"><span>01 // about</span></div>
    <h2 class="section-title">Who I am</h2>

    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr] items-start">
      <div class="space-y-5 text-[color:var(--color-text-dim)] text-lg leading-relaxed">
        <p>
          I'm an offensive security engineer with over a decade of hands-on experience finding and
          exploiting weaknesses across cloud, web, and mobile — then translating those findings into
          real risk reduction for the businesses I work with.
        </p>
        <p>
          Currently based in the Netherlands, working at <span class="text-[color:var(--color-accent)] font-mono">{site.company}</span> in {site.companyCity}.
          My focus areas are Azure red teaming, Active Directory attack paths, and web application security —
          the intersection where modern enterprises get hurt most.
        </p>
        <p>
          This site is where I document what I learn as I keep sharpening the craft — writeups,
          tooling notes, war stories, and the occasional deep dive.
        </p>

        <div class="pt-4 flex flex-wrap items-center gap-6 font-mono text-sm text-[color:var(--color-text-muted)]">
          <span class="flex items-center gap-2">
            <Icon name="lucide:map-pin" class="w-4 h-4 text-[color:var(--color-accent)]" />
            {site.location}
          </span>
          <span class="flex items-center gap-2">
            <Icon name="lucide:briefcase" class="w-4 h-4 text-[color:var(--color-accent)]" />
            {site.company}
          </span>
          <span class="flex items-center gap-2">
            <Icon name="lucide:languages" class="w-4 h-4 text-[color:var(--color-accent)]" />
            {site.languages.map((l) => l.name).join(' · ')}
          </span>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3">
        {stats.map((s) => (
          <div class="card text-center">
            <div class="font-display text-3xl md:text-4xl font-bold text-[color:var(--color-accent)]">
              {s.value}
            </div>
            <div class="mt-1 font-mono text-xs uppercase tracking-wider text-[color:var(--color-text-muted)]">
              {s.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
