---
import { skillGroups } from '../data/skills';
import { Icon } from 'astro-icon/components';
---
<section id="skills" class="py-20 md:py-28" style="background: var(--color-bg-elev); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
  <div class="container-x">
    <div class="section-label"><span>04 // capabilities</span></div>
    <h2 class="section-title">What I bring</h2>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {skillGroups.map((group) => (
        <div class="card group">
          <div class="flex items-center gap-3">
            <div
              class="inline-flex items-center justify-center w-10 h-10 rounded-md"
              style="background: var(--color-accent-glow); border: 1px solid rgba(255,176,32,0.2);"
            >
              <Icon name={group.icon} class="w-5 h-5 text-[color:var(--color-accent)]" />
            </div>
            <h3 class="font-display text-base font-semibold text-[color:var(--color-text)]">
              {group.title}
            </h3>
          </div>
          <ul class="mt-4 space-y-2">
            {group.items.map((item) => (
              <li class="flex items-start gap-2 text-sm text-[color:var(--color-text-dim)]">
                <span class="mt-2 w-1 h-1 rounded-full flex-shrink-0" style="background: var(--color-accent);"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
