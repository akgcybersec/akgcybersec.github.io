---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { blogReferences } from '../../data/blog-references';

type SeriesLink = {
  title: string;
  href: string;
  part: number;
};

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  const seriesMap = new Map<string, typeof posts>();
  for (const post of posts) {
    if (!post.data.seriesSlug) continue;
    const group = seriesMap.get(post.data.seriesSlug) ?? [];
    group.push(post);
    seriesMap.set(post.data.seriesSlug, group);
  }
  for (const [slug, group] of seriesMap) {
    seriesMap.set(
      slug,
      [...group].sort((a, b) => {
        const ap = a.data.seriesPart ?? Number.MAX_SAFE_INTEGER;
        const bp = b.data.seriesPart ?? Number.MAX_SAFE_INTEGER;
        if (ap !== bp) return ap - bp;
        return a.data.date.getTime() - b.data.date.getTime();
      }),
    );
  }

  return posts.map((post) => {
    let prevInSeries: SeriesLink | undefined;
    let nextInSeries: SeriesLink | undefined;

    if (post.data.seriesSlug && post.data.seriesPart) {
      const siblings = seriesMap.get(post.data.seriesSlug) ?? [];
      const idx = siblings.findIndex((p) => p.id === post.id);
      if (idx > 0) {
        const prev = siblings[idx - 1];
        prevInSeries = {
          title: prev.data.title,
          href: `/blog/${prev.id}/`,
          part: prev.data.seriesPart!,
        };
      }
      if (idx >= 0 && idx < siblings.length - 1) {
        const next = siblings[idx + 1];
        nextInSeries = {
          title: next.data.title,
          href: `/blog/${next.id}/`,
          part: next.data.seriesPart!,
        };
      }
    }

    return {
      params: { slug: post.id },
      props: { post, prevInSeries, nextInSeries },
    };
  });
}

const { post, prevInSeries, nextInSeries } = Astro.props;
const { Content } = await render(post);
const refEntry = blogReferences[post.id] ?? { references: [], related: [] };
---
<BlogPost
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  updated={post.data.updated}
  tags={post.data.tags}
  seriesTitle={post.data.seriesTitle}
  seriesPart={post.data.seriesPart}
  prevInSeries={prevInSeries}
  nextInSeries={nextInSeries}
  references={refEntry.references}
  related={refEntry.related}
>
  <Content />
</BlogPost>
