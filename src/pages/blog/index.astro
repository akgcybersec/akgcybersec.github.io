---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const formatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<BaseLayout title="Blog" description="Notes, writeups, and deep dives from Aswin G.">
  <section class="container-x py-16 md:py-24">
    <div class="section-label"><span>// blog</span></div>
    <h1 class="section-title">Field notes</h1>
    <p class="max-w-2xl text-[color:var(--color-text-dim)] mb-10">
      Writeups, tooling notes, war stories from red team engagements, and things I'm learning along the way.
    </p>

    {posts.length === 0 ? (
      <div class="card text-center py-20">
        <Icon name="lucide:file-text" class="w-8 h-8 mx-auto text-[color:var(--color-text-muted)]" />
        <p class="mt-4 text-[color:var(--color-text-dim)]">No posts yet. Check back soon.</p>
      </div>
    ) : (
      <div class="space-y-4">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="card flex flex-col sm:flex-row sm:items-baseline gap-4 sm:gap-8 group"
          >
            <div class="font-mono text-xs text-[color:var(--color-text-muted)] shrink-0 sm:w-28 sm:pt-1">
              {formatter.format(post.data.date)}
            </div>
            <div class="flex-1 min-w-0">
              <h2 class="font-display text-xl font-semibold text-[color:var(--color-text)] group-hover:text-[color:var(--color-accent)] transition">
                {post.data.title}
              </h2>
              <p class="mt-2 text-sm text-[color:var(--color-text-dim)]">
                {post.data.description}
              </p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
            <Icon
              name="lucide:arrow-up-right"
              class="w-4 h-4 text-[color:var(--color-text-muted)] group-hover:text-[color:var(--color-accent)] transition sm:mt-1"
            />
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
